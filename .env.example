# ── Tatum RPC (required) ──────────────────────────────────────────────────────
# Sign up at https://tatum.com → Dashboard → API Keys
# Free tier: 10 req/s on Sui Mainnet
TATUM_API_KEY=your_tatum_api_key_here

# Optional — override the Tatum Sui RPC endpoint (defaults shown)
# TATUM_SUI_RPC_URL=https://api.tatum.io/v3/blockchain/node/SUI

# ── Walrus Storage (optional overrides) ───────────────────────────────────────
# Testnet (default, no auth required):
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Mainnet — see https://docs.walrus.space for available publisher/aggregator nodes
# WALRUS_PUBLISHER_URL=https://publisher.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space
